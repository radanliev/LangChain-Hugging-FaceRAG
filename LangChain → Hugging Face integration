.github/workflows/ci.yml

name: CI - build index & smoke test

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Cache pip
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('**/requirements.txt') }}
          restore-keys: |
            ${{ runner.os }}-pip-

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Prepare sample data
        run: |
          mkdir -p data
          echo "This is a CI sample document. It contains simple text for index build." > data/sample.txt

      - name: Build FAISS index
        run: |
          python src/ingest.py --data-dir data --index-path indexes/ci_faiss_index.pkl

      - name: Smoke test - index exists
        run: |
          if [ -f indexes/ci_faiss_index.pkl ]; then
            echo "Index built successfully."
          else
            echo "Index not found!" >&2
            exit 1
          fi


