# src/run.py
import argparse
from agent import SimpleRAGAgent

def main(index_path):
    agent = SimpleRAGAgent(index_path)
    print("Agent ready. Type your question (Ctrl-C to quit).")
    try:
        while True:
            q = input(">> ").strip()
            if not q:
                continue
            print("Answer:")
            print(agent.answer(q))
            print()
    except KeyboardInterrupt:
        print("\nExiting.")

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--index", required=True)
    args = parser.parse_args()
    main(args.index)


